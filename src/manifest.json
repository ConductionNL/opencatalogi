			},
			"_note": "CnIndexPage-based but schema/register are runtime-resolved from IAppConfig (tenant-configured). Keeping type:'custom' until @resolve: sentinel support."
		},
		{
			"id": "ThemeDetail",
			"route": "/themes/:id",
			"type": "dashboard",
			"title": "Theme",
			"config": {
				"widgets": [
