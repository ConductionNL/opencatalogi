# Docker Compose default profile — makes `docker compose up` implicitly use
# the PostgreSQL DB path (which is the recommended dev stack — required for
# OpenRegister's _fuzzy=true trigram-similarity + pgvector semantic search).
#
# Override to test compatibility on MariaDB:
#   docker compose --profile mariadb up
#
# Docker Compose 2.20+ reads COMPOSE_PROFILES from this .env file
# automatically; older versions require exporting it in the shell env.
COMPOSE_PROFILES=postgres
